generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int          @id @default(autoincrement())
  email      String       @unique
  googleSub  String?      @unique
  name       String?
  avatarUrl  String?
  region     String?
  ou         String?
  title      String?
  onboardingCompleted Boolean @default(false)
  role       Role         @default(MEMBER)
  teamId     Int
  team       Team         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  prompts    Prompt[]
  skills     Skill[]
  contextDocuments ContextDocument[]
  favorites  Favorite[]
  ratings    Rating[]
  versions   PromptVersion[]
  usage      UsageEvent[]
  collections Collection[] @relation("CollectionCreator")
  collectionMemberships CollectionUser[] @relation("CollectionMembership")
  skillFavorites    SkillFavorite[]
  skillUsageEvents  SkillUsageEvent[]
  skillRatings      SkillRating[]
  contextFavorites  ContextFavorite[]
  contextUsageEvents ContextUsageEvent[]
  contextRatings    ContextRating[]
  builds            Build[]
  buildFavorites    BuildFavorite[]
  buildUsageEvents  BuildUsageEvent[]
  buildRatings      BuildRating[]
  toolRequestsReviewed ToolRequest[]
}

model Team {
  id          Int          @id @default(autoincrement())
  name        String
  slug        String       @unique
  users       User[]
  prompts     Prompt[]
  skills      Skill[]
  contextDocuments ContextDocument[]
  builds      Build[]
  tags        Tag[]
  collections Collection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Prompt {
  id           Int               @id @default(autoincrement())
  teamId       Int
  ownerId      Int
  title        String
  summary      String?
  body         String
  visibility   PromptVisibility  @default(PUBLIC)
  status       PromptStatus      @default(DRAFT)
  modelHint    String?
  tools        String[]          @default([])
  modality     PromptModality    @default(TEXT)
  thumbnailUrl String?
  thumbnailStatus ThumbnailStatus @default(PENDING)
  thumbnailError String?
  isSmartPick  Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  team         Team              @relation(fields: [teamId], references: [id], onDelete: Restrict)
  owner        User              @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  versions     PromptVersion[]
  promptTags   PromptTag[]
  collections  CollectionPrompt[]
  favorites    Favorite[]
  ratings      Rating[]
  variables    PromptVariable[]
  usageEvents  UsageEvent[]
}

model Skill {
  id              Int              @id @default(autoincrement())
  teamId          Int
  ownerId         Int
  title           String
  summary         String?
  body            String
  visibility      PromptVisibility @default(PUBLIC)
  status          PromptStatus     @default(DRAFT)
  tools           String[]         @default([])
  thumbnailUrl    String?
  thumbnailStatus ThumbnailStatus  @default(PENDING)
  thumbnailError  String?
  isSmartPick     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  team            Team             @relation(fields: [teamId], references: [id], onDelete: Restrict)
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  favorites       SkillFavorite[]
  usageEvents     SkillUsageEvent[]
  variables       SkillVariable[]
  ratings         SkillRating[]
  collections     CollectionSkill[]

  @@index([teamId, updatedAt])
}

model ContextDocument {
  id              Int              @id @default(autoincrement())
  teamId          Int
  ownerId         Int
  title           String
  summary         String?
  body            String
  visibility      PromptVisibility @default(PUBLIC)
  status          PromptStatus     @default(DRAFT)
  tools           String[]         @default([])
  thumbnailUrl    String?
  thumbnailStatus ThumbnailStatus  @default(PENDING)
  thumbnailError  String?
  isSmartPick     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  team            Team             @relation(fields: [teamId], references: [id], onDelete: Restrict)
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  favorites       ContextFavorite[]
  usageEvents     ContextUsageEvent[]
  variables       ContextVariable[]
  ratings         ContextRating[]
  collections     CollectionContext[]

  @@index([teamId, updatedAt])
}

model Build {
  id              Int              @id @default(autoincrement())
  teamId          Int
  ownerId         Int
  title           String
  summary         String?
  buildUrl        String
  supportUrl      String?
  visibility      PromptVisibility @default(PUBLIC)
  status          PromptStatus     @default(DRAFT)
  thumbnailUrl    String?
  thumbnailStatus ThumbnailStatus  @default(PENDING)
  thumbnailError  String?
  isSmartPick     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  team            Team             @relation(fields: [teamId], references: [id], onDelete: Restrict)
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  favorites       BuildFavorite[]
  usageEvents     BuildUsageEvent[]
  ratings         BuildRating[]
  collections     CollectionBuild[]

  @@index([teamId, updatedAt])
}

model PromptVersion {
  id          Int      @id @default(autoincrement())
  promptId    Int
  version     Int
  body        String
  changelog   String?
  createdById Int
  createdAt   DateTime @default(now())
  prompt      Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([promptId, version])
}

model Tag {
  id        Int      @id @default(autoincrement())
  teamId    Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Restrict)
  promptTags PromptTag[]

  @@unique([teamId, name])
}

model PromptTag {
  id       Int    @id @default(autoincrement())
  promptId Int
  tagId    Int
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([promptId, tagId])
}

model Collection {
  id          Int                @id @default(autoincrement())
  teamId      Int
  name        String
  description String?
  createdById Int
  isSystem    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  team        Team               @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdBy   User               @relation("CollectionCreator", fields: [createdById], references: [id], onDelete: Restrict)
  prompts     CollectionPrompt[]
  skills      CollectionSkill[]
  contexts    CollectionContext[]
  builds      CollectionBuild[]
  users       CollectionUser[]

  @@unique([teamId, name])
}

model CollectionPrompt {
  id           Int        @id @default(autoincrement())
  collectionId Int
  promptId     Int
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  prompt       Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([collectionId, promptId])
}

model CollectionSkill {
  id           Int        @id @default(autoincrement())
  collectionId Int
  skillId      Int
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([collectionId, skillId])
}

model CollectionContext {
  id           Int             @id @default(autoincrement())
  collectionId Int
  contextId    Int
  sortOrder    Int             @default(0)
  collection   Collection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  context      ContextDocument @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@unique([collectionId, contextId])
}

model CollectionBuild {
  id           Int        @id @default(autoincrement())
  collectionId Int
  buildId      Int
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  build        Build      @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([collectionId, buildId])
}

model CollectionUser {
  id           Int        @id @default(autoincrement())
  collectionId Int
  userId       Int
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  user         User       @relation("CollectionMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collectionId, userId])
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  promptId  Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
}

model Rating {
  id        Int      @id @default(autoincrement())
  userId    Int
  promptId  Int
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
}

model PromptVariable {
  id           Int      @id @default(autoincrement())
  promptId     Int
  key          String
  label        String?
  defaultValue String?
  required     Boolean  @default(false)
  prompt       Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, key])
}

model SkillVariable {
  id           Int      @id @default(autoincrement())
  skillId      Int
  key          String
  label        String?
  defaultValue String?
  required     Boolean  @default(false)
  skill        Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, key])
}

model ContextVariable {
  id           Int             @id @default(autoincrement())
  contextId    Int
  key          String
  label        String?
  defaultValue String?
  required     Boolean         @default(false)
  context      ContextDocument @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@unique([contextId, key])
}

model UsageEvent {
  id        Int         @id @default(autoincrement())
  promptId  Int
  userId    Int
  action    UsageAction
  createdAt DateTime    @default(now())
  prompt    Prompt      @relation(fields: [promptId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([promptId, action, createdAt])
}

model SkillFavorite {
  id        Int      @id @default(autoincrement())
  skillId   Int
  userId    Int
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([skillId, userId])
}

model SkillUsageEvent {
  id        Int      @id @default(autoincrement())
  skillId   Int
  userId    Int
  eventType String   @default("VIEW")
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([userId])
}

model ContextFavorite {
  id        Int             @id @default(autoincrement())
  contextId Int
  userId    Int
  createdAt DateTime        @default(now())
  context   ContextDocument @relation(fields: [contextId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contextId, userId])
}

model ContextUsageEvent {
  id        Int             @id @default(autoincrement())
  contextId Int
  userId    Int
  eventType String          @default("VIEW")
  createdAt DateTime        @default(now())
  context   ContextDocument @relation(fields: [contextId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contextId])
  @@index([userId])
}

model SkillRating {
  id        Int      @id @default(autoincrement())
  userId    Int
  skillId   Int
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model ContextRating {
  id        Int             @id @default(autoincrement())
  userId    Int
  contextId Int
  value     Int
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  context   ContextDocument @relation(fields: [contextId], references: [id], onDelete: Cascade)

  @@unique([userId, contextId])
}

model BuildFavorite {
  id        Int      @id @default(autoincrement())
  buildId   Int
  userId    Int
  createdAt DateTime @default(now())
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([buildId, userId])
}

model BuildUsageEvent {
  id        Int      @id @default(autoincrement())
  buildId   Int
  userId    Int
  eventType String   @default("VIEW")
  createdAt DateTime @default(now())
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([buildId])
  @@index([userId])
}

model BuildRating {
  id        Int      @id @default(autoincrement())
  userId    Int
  buildId   Int
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  build     Build    @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([userId, buildId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum PromptVisibility {
  PUBLIC
  TEAM
  PRIVATE
}

enum PromptStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UsageAction {
  VIEW
  COPY
  LAUNCH
}

enum PromptModality {
  TEXT
  CODE
  IMAGE
  VIDEO
  AUDIO
  MULTIMODAL
}

enum ThumbnailStatus {
  PENDING
  READY
  FAILED
}

model ToolRequest {
  id                 Int               @id @default(autoincrement())
  name               String
  salesforceApproved Boolean
  detailsUrl         String
  description        String
  submitterFirstName String
  submitterLastName  String
  submitterEmail     String
  status             ToolRequestStatus @default(PENDING)
  reviewedAt         DateTime?
  reviewedById       Int?
  reviewedBy         User?             @relation(fields: [reviewedById], references: [id])
  reviewNotes        String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([status, createdAt])
}

enum ToolRequestStatus {
  PENDING
  APPROVED
  DECLINED
  ON_HOLD
}
