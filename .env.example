DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgresql-triangular-41066?schema=public"
PORT=5000
NODE_ENV=development

# Mailgun SMTP Configuration
# Production uses the verified custom domain mail.mysalesforcedemo.com (NOT the
# sandbox). Get SMTP credentials from: Mailgun Dashboard > Sending > Domain
# Settings > SMTP credentials for that domain.
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mail.mysalesforcedemo.com
SMTP_PASS=your-mailgun-smtp-password
SMTP_FROM=noreply@mail.mysalesforcedemo.com
TOOL_REQUEST_NOTIFY_EMAIL=admin@example.com

# Governance sweep rollout flag. When false (default), the daily sweep runs in
# dry-run mode so ops can review the audit log for a week before flipping on.
# Set to "true" in production only after the audit review window.
GOVERNANCE_SWEEP_ENABLED=false
